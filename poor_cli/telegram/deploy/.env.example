# required
TELEGRAM_TOKEN=your-telegram-bot-token
POOR_CLI_TELEGRAM_TOKEN=your-telegram-bot-token

# provider config
POOR_CLI_PROVIDER=gemini
POOR_CLI_MODEL=gemini-2.5-flash

# API keys (set the one matching your provider)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# access control (comma-separated Telegram user IDs, empty = open)
ALLOWED_USERS=

# sandbox preset (review-only, permissive, strict)
SANDBOX_PRESET=review-only

# webhook (optional, leave empty for polling)
WEBHOOK_URL=
WEBHOOK_PORT=8443

# rate limiting
RATE_LIMIT_USER=10
RATE_LIMIT_GLOBAL=100

# max concurrent sessions
MAX_SESSIONS=20
