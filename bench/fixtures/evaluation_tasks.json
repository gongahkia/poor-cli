{
  "schema_version": "poor-cli-evaluation-tasks-v1",
  "tasks": [
    {
      "id": "eval-simple-edit",
      "category": "simple_edit",
      "prompt": "Change one constant and run its focused test.",
      "success_criteria": ["minimal diff", "focused test passes"]
    },
    {
      "id": "eval-multifile-refactor",
      "category": "multi_file_refactor",
      "prompt": "Move duplicated helper logic into one shared helper without behavior change.",
      "success_criteria": ["all callers updated", "existing tests pass"]
    },
    {
      "id": "eval-bug-fix",
      "category": "bug_fix",
      "prompt": "Fix a failing fixture bug and prove it with pytest.",
      "success_criteria": ["regression covered", "pytest passes"]
    },
    {
      "id": "eval-ambiguous-design",
      "category": "ambiguous_design",
      "prompt": "Resolve an ambiguous CLI behavior with explicit assumptions and docs.",
      "success_criteria": ["assumptions recorded", "CLI behavior deterministic"]
    },
    {
      "id": "eval-graph-lookup",
      "category": "graph_lookup",
      "prompt": "Use graph tools to find a symbol definition and its callers.",
      "success_criteria": ["graph tools used", "answer cites symbol paths"]
    },
    {
      "id": "eval-web-research",
      "category": "web_research",
      "prompt": "Answer a current API question with web citations and replayable fetch cache.",
      "success_criteria": ["source URLs recorded", "web cache replayable"]
    }
  ],
  "modes": ["direct", "planner_executor", "swarm", "fusion_planner", "second_model_review"],
  "metrics": ["passed", "cost_usd", "duration_seconds", "failure_category", "run_id"]
}
