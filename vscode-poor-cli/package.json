{
  "name": "poor-cli",
  "displayName": "poor-cli",
  "description": "AI coding assistant — multi-provider, multi-surface",
  "version": "0.1.0",
  "publisher": "poor-cli",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "poor-cli.chat",
        "title": "poor-cli: Open Chat"
      },
      {
        "command": "poor-cli.inlineComplete",
        "title": "poor-cli: Inline Completion"
      },
      {
        "command": "poor-cli.reviewFile",
        "title": "poor-cli: Review Current File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "poor-cli",
          "title": "poor-cli",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "poor-cli": [
        {
          "type": "webview",
          "id": "poor-cli.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "poor-cli",
      "properties": {
        "poor-cli.provider": {
          "type": "string",
          "default": "gemini",
          "enum": ["gemini", "openai", "anthropic", "ollama"],
          "description": "Default AI provider"
        },
        "poor-cli.model": {
          "type": "string",
          "default": "",
          "description": "Model name (empty = provider default)"
        },
        "poor-cli.serverPath": {
          "type": "string",
          "default": "poor-cli-server",
          "description": "Path to poor-cli-server binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
