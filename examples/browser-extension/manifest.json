{
  "manifest_version": 3,
  "name": "Dude UEN Overlay Prototype",
  "version": "0.1.0",
  "description": "Detect Singapore UEN-like text on the current page and open a click-triggered Dude dossier preview.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:5173/*",
    "http://localhost:8787/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
