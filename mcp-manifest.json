{
  "name": "haus",
  "title": "Haus",
  "version": "0.1.0",
  "mcp_name": "io.github.gongahkia/haus",
  "repository": "https://github.com/gongahkia/haus",
  "homepage": "https://github.com/gongahkia/haus#readme",
  "license": "MIT",
  "language": "Python",
  "runtime": {
    "name": "uvx",
    "requires_python": ">=3.10"
  },
  "transport": {
    "type": "stdio",
    "command": "uvx --from git+https://github.com/gongahkia/haus haus mcp"
  },
  "listing": {
    "short_description": "MCP-native HDB BTO floor-plan editor that lets agents furnish Singapore flats.",
    "long_description": "Haus is an open-source SVG/GLB floor-plan editor for Singapore HDB BTO layouts. Its stdio MCP server lets assistants load real BTO flat layouts, place and edit furniture, tag rooms, check sightlines and walkways, and write the result back to the browser editor.",
    "category": "Design tools",
    "tags": [
      "mcp",
      "floor-plan",
      "interior-design",
      "hdb",
      "bto",
      "singapore",
      "threejs",
      "layout"
    ],
    "use_cases": [
      "Furnish Singapore HDB BTO floor plans through agent tool calls.",
      "Load real BTO layout presets into a browser-based 3D editor.",
      "Check furniture placement, room tags, sightlines, and walkway clearance."
    ]
  },
  "install": {
    "view_command": "uvx --from git+https://github.com/gongahkia/haus haus view",
    "mcp_command": "uvx --from git+https://github.com/gongahkia/haus haus mcp --layout ~/.haus/viewer/mcp-layout.json",
    "pypi_future_mcp_command": "uvx haus mcp"
  },
  "client_config": {
    "claude_desktop": {
      "mcpServers": {
        "haus": {
          "command": "uvx",
          "args": [
            "--from",
            "git+https://github.com/gongahkia/haus",
            "haus",
            "mcp",
            "--layout",
            "/Users/YOUR_USER/.haus/viewer/mcp-layout.json"
          ]
        }
      }
    }
  },
  "capabilities": {
    "tools": [
      "design_room",
      "design_flat",
      "list_furniture_catalog",
      "list_objects",
      "get_object_details",
      "get_layout_summary",
      "get_layout_json",
      "add_furniture",
      "add_wall",
      "move_object",
      "rotate_object",
      "resize_object",
      "set_color",
      "set_visibility",
      "duplicate_object",
      "swap_furniture",
      "remove_object",
      "remove_objects_by_type",
      "clear_layout",
      "batch_move",
      "align_objects",
      "distribute_objects",
      "snap_to_grid",
      "measure_distance",
      "find_nearest",
      "check_overlap",
      "find_objects_in_area",
      "check_sightline",
      "suggest_furniture_placement",
      "auto_place_furniture",
      "suggest_placement_json",
      "simulate_layout_options",
      "apply_simulated_option",
      "rename_object",
      "find_by_name",
      "tag_room",
      "list_rooms",
      "compute_room_area",
      "list_room_templates",
      "apply_room_template",
      "score_doorway_accessibility",
      "score_walkway"
    ],
    "resources": [],
    "prompts": []
  },
  "submission_status": [
    {
      "target": "mcp.so",
      "status": "ready_for_manual_submission",
      "last_checked": "2026-06-03",
      "path": "https://mcp.so/submit"
    },
    {
      "target": "mcp.pizza",
      "status": "pending_submission_path",
      "last_checked": "2026-06-03",
      "path": "https://www.mcp.pizza/mcp-servers"
    },
    {
      "target": "PulseMCP",
      "status": "ready_for_manual_submission",
      "last_checked": "2026-06-03",
      "path": "https://www.pulsemcp.com/submit"
    },
    {
      "target": "Smithery",
      "status": "blocked_until_remote_server_or_mcpb_bundle",
      "last_checked": "2026-06-03",
      "path": "https://smithery.ai/docs/build/publish"
    },
    {
      "target": "Anthropic Connectors Directory",
      "status": "blocked_until_mcpb_bundle_or_remote_connector",
      "last_checked": "2026-06-03",
      "path": "https://claude.com/docs/connectors/building/submission"
    },
    {
      "target": "Official MCP Registry",
      "status": "blocked_until_pypi_release_and_package_verification",
      "last_checked": "2026-06-03",
      "path": "https://modelcontextprotocol.io/registry"
    }
  ]
}
