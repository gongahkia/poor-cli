# Junas configuration
APP_NAME=Junas
DEBUG=true
DATABASE_URL=postgresql+asyncpg://junas:junas@localhost:5432/junas
ELASTICSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# vendor data paths
LECARD_DATA_ROOT=../vendor-data/LeCaRD/data
NER_GAZETTEER_DIR=../vendor-data/Legal-Entity-Recognition/gazetteers
ROME_STATUTE_DATA_PATH=../vendor-data/datasets/Intergovernmental/RomeStatute/RomeStatute.json

# LLM providers (server-side defaults, users can override via BYOK)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=default

# BYOK support
ALLOW_BYOK=true

# auth (optional)
REQUIRE_AUTH=false
API_KEYS=
RATE_LIMIT_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000
