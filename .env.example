SG_API_ONEMAP_EMAIL=you@example.com
SG_API_ONEMAP_PASSWORD=your-onemap-password
SG_API_URA_KEY=your-ura-api-key
SG_API_LTA_KEY=your-lta-api-key
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=your-splunk-mcp-bearer-token
SPLUNK_MCP_ALLOWED_INDEXES=main,security
SWEE_SHIELD_RUNTIME_SCAN_MODE=neutralize
# local Splunk trials with self-signed certs only:
# NODE_TLS_REJECT_UNAUTHORIZED=0
DUDE_WEB_ORIGIN_ALLOWLIST=http://localhost:5173
DUDE_WORKSPACE_AUTH_REQUIRED=false
DUDE_ALLOW_INSECURE_PRODUCTION_LOCAL_AUTH=false
DUDE_DEBUG_LOGS=0
DUDE_DEBUG_LOG_PATH=
TINYFISH_API_KEY=your-tinyfish-api-key
DUDE_AI_PROVIDER=openai
DUDE_AI_MODEL=
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
