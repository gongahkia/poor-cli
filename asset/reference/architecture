digraph architecture {
	bgcolor=white dpi=200 fontname=Helvetica fontsize=13 nodesep=0.5 pad=0.4 rankdir=LR ranksep=1.2
	node [color="#dee2e6" fillcolor="#f8f9fa" fontcolor="#212529" fontname=Helvetica fontsize=11 margin="0.15,0.08" penwidth=1.2 shape=box style="rounded,filled"]
	edge [arrowsize=0.7 color="#6c757d" fontcolor="#495057" fontname=Helvetica fontsize=9 penwidth=1.0]
	subgraph cluster_input {
		bgcolor="#f1f3f5" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label=Input style=rounded
		seuss_file [label=".seuss file" fillcolor="#d0ebff" shape=note]
		csv_in [label=CSV fillcolor="#d0ebff" shape=note]
		gedcom_in [label=GEDCOM fillcolor="#d0ebff" shape=note]
		jsonld_in [label="JSON-LD" fillcolor="#d0ebff" shape=note]
		repl_in [label="REPL (stdin)" fillcolor="#e7f5ff" shape=box]
	}
	subgraph cluster_import {
		bgcolor="#fff9db" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label="Import Pipeline
src/import" style=rounded
		csv_imp [label="CSV Import"]
		gedcom_imp [label="GEDCOM Import"]
		jsonld_imp [label="JSON-LD Import"]
		validate_imp [label="Import Validator" fillcolor="#fff3bf"]
	}
	subgraph cluster_frontend {
		bgcolor="#e3fafc" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label="Frontend
src/cli + src/lang" style=rounded
		cli [label="CLI (clap)"]
		reader [label="File Reader"]
		parser [label="PEG Parser (pest)"]
		ast [label=AST fillcolor="#c5f6fa" shape=component]
	}
	subgraph cluster_core {
		bgcolor="#f3f0ff" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label="Core Engine
src/eval + src/model + src/ext" style=rounded
		evaluator [label=Evaluator fillcolor="#e5dbff"]
		world [label="World Model" fillcolor="#d0bfff" shape=box3d]
		type_reg [label="Type Registry"]
		query [label="Query Engine"]
		validator [label="Structural Validator"]
	}
	subgraph cluster_layout {
		bgcolor="#fff4e6" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label="Layout Engine
src/layout" style=rounded
		lane_compact [label="Lane Compaction"]
		connectors [label="Fork/Merge
Connectors"]
		labels [label="Label Collision
Resolution"]
	}
	subgraph cluster_render {
		bgcolor="#ebfbee" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label="Render + Output
src/render + src/tui" style=rounded
		svg_r [label="SVG Renderer" fillcolor="#d3f9d8"]
		png_r [label="PNG (resvg)"]
		pdf_r [label="PDF (printpdf)"]
		anim_r [label="Animated SVG
(SMIL + CSS)"]
		tui_r [label="TUI (ratatui)" fillcolor="#d3f9d8"]
	}
	subgraph cluster_output {
		bgcolor="#f1f3f5" color="#adb5bd" fontcolor="#212529" fontname="Helvetica Bold" fontsize=12 label=Output style=rounded
		svg_out [label=".svg" fillcolor="#d0ebff" shape=note]
		png_out [label=".png" fillcolor="#d0ebff" shape=note]
		pdf_out [label=".pdf" fillcolor="#d0ebff" shape=note]
		terminal [label=Terminal fillcolor="#e7f5ff" shape=box]
	}
	csv_in -> csv_imp
	gedcom_in -> gedcom_imp
	jsonld_in -> jsonld_imp
	csv_imp -> validate_imp
	gedcom_imp -> validate_imp
	jsonld_imp -> validate_imp
	validate_imp -> reader [label=".seuss"]
	seuss_file -> reader
	repl_in -> cli [label=stdin]
	cli -> reader
	reader -> parser
	parser -> ast
	ast -> evaluator [label=eval]
	evaluator -> world
	world -> type_reg
	world -> query
	world -> validator
	world -> lane_compact [label=compute]
	lane_compact -> connectors
	lane_compact -> labels
	lane_compact -> svg_r [label=render]
	lane_compact -> tui_r
	svg_r -> png_r
	svg_r -> pdf_r
	svg_r -> anim_r
	svg_r -> svg_out
	png_r -> png_out
	pdf_r -> pdf_out
	tui_r -> terminal
	anim_r -> svg_out
}
