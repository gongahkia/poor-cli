{
  "name": "@dude/mcp",
  "version": "0.1.0",
  "mcpName": "io.github.gongahkia/dude-mcp",
  "description": "Dude MCP backend for Singapore company/UEN CDD reports with cited registry evidence, supplemental analyst-review signals, report exports, and runtime ops tools.",
  "keywords": [
    "CDD Query",
    "Business Dossier",
    "ACRA",
    "BCA",
    "BOA",
    "CEA",
    "GeBIZ",
    "HSA",
    "HLB",
    "External Diligence",
    "Operations"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "assets",
    "openapi.json",
    "!dist/**/__tests__/**",
    "!dist/**/fixtures/**",
    "!dist/**/mock-server/**"
  ],
  "bin": {
    "dude-mcp": "dist/index.js",
    "sg-apis-mcp": "dist/index.js",
    "sg-data": "dist/cli.js"
  },
  "scripts": {
    "prepublishOnly": "tsc --build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dude/shared": "0.1.0",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "jose": "^6.1.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
