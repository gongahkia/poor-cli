{
  "name": "sg-skills",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "lint": "eslint packages/*/src/**/*.ts",
    "verify": "node ./scripts/verify.mjs",
    "dev": "tsc --build --watch",
    "mock-server": "tsx packages/mcp-server/src/__tests__/mock-server/index.ts",
    "test:smoke:packaging": "node ./scripts/smoke-packages.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
